# Base mainnet profile — copy to `.env.mainnet` for x402 mainnet canary.
# Keep `.env` on Sepolia for day-to-day dev; use `pnpm --filter @lmxcloud/api dev:mainnet`.

# SIWE_CHAIN_ID=8453
# BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your_key
# USDC_CONTRACT_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# TREASURY_ADDRESS=0xYourTreasuryWallet
# DEPOSIT_MAX_LOG_BLOCK_RANGE=10
# Leave ANCHOR_* unset until mainnet anchor contract is deployed
# Deploy: pnpm deploy:anchor:mainnet  (needs ~0.001 ETH on deployer wallet)
# ANCHOR_CONTRACT_ADDRESS=0x...
# ANCHOR_PRIVATE_KEY=0x...   # deployer/owner wallet — keep funded for batch anchor gas
# ANCHOR_BATCH_INTERVAL_MS=300000
