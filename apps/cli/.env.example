# LMX Cloud console chat — copy to apps/cli/.env or set in your shell

LMX_API_URL=http://localhost:3000

# Optional: skip the demo/sign-in menu and use a fixed credential
# LMX_API_KEY=lmx_...
# LMX_SESSION_TOKEN=lmx_sess_...
# LMX_EMAIL=you@example.com

# Default model alias (see GET /v1/models)
LMX_MODEL=llama-3-70b

# Optional routing: cheapest | fastest | depin-only | provider:ionet
# LMX_PREFER=cheapest
