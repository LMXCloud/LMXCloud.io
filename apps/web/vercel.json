{
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "cd ../.. && pnpm --filter @lmxcloud/shared build && pnpm --filter @lmxcloud/web build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/((?!robots\\.txt|sitemap\\.xml).*)",
      "destination": "/index.html"
    }
  ]
}
